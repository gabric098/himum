# ──────────────────────────────────────────────
# Required API keys
# ──────────────────────────────────────────────

# Deepgram — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ──────────────────────────────────────────────
# Optional — sensible defaults provided
# ──────────────────────────────────────────────

# ElevenLabs voice ID (default: Rachel)
# Find IDs at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Groq model for the LLM turn
# Check current model IDs at https://console.groq.com/docs/models
GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct

# System prompt — keep it concise; this is a voice assistant
SYSTEM_PROMPT=You are a helpful, concise voice assistant. Keep answers brief and natural for spoken conversation. Avoid markdown, bullet points, or lists — just speak plainly.

# Maximum number of conversation turns to keep in context (user+assistant pairs)
MAX_HISTORY_TURNS=10

# Drop mic audio while the assistant is speaking. Use this when running on
# laptop speakers to prevent the app from picking up its own TTS output.
# Trade-off: disables barge-in (you can't interrupt the assistant). Leave off
# (or unset) when wearing headphones.
MUTE_MIC_WHILE_SPEAKING=false

# Extra ms to keep the mic muted after the assistant stops speaking, to cover
# CoreAudio drain + room reverb. Only used when MUTE_MIC_WHILE_SPEAKING=true.
# Bump higher (800–1000) if echo still leaks; lower (300) for snappier turns.
SPEAK_COOLDOWN_MS=500

# VAD sensitivity — raise positiveSpeechThreshold to require more confident speech
# before triggering (0–1, default: 0.6)
VAD_POSITIVE_THRESHOLD=0.6
VAD_NEGATIVE_THRESHOLD=0.45
